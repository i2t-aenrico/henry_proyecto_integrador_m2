# --- Embeddings ---
# Proveedor de embeddings: "openai" o "local"
EMBEDDING_PROVIDER=local

# Requerido solo si EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=your-key-here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Usado solo si EMBEDDING_PROVIDER=local (corre en CPU, sin API key)
LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Generación (LLM) ---
# Proveedor de generación: "anthropic" o "openai"
LLM_PROVIDER=anthropic

ANTHROPIC_API_KEY=your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6

# Si LLM_PROVIDER=openai, reutiliza OPENAI_API_KEY de arriba
OPENAI_LLM_MODEL=gpt-4o-mini

# --- Pipeline de consulta ---
TOP_K=5
INDEX_DIR=outputs/index
